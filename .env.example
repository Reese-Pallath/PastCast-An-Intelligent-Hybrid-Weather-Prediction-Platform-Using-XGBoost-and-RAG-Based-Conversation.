# ── Frontend (CRA) ──────────────────────────────────────────────
REACT_APP_OPENWEATHER_API=your_openweather_api_key_here
REACT_APP_OPENWEATHER_API_KEY=your_openweather_api_key_here
REACT_APP_GEMINI=your_gemini_api_key_here

# API endpoint for frontend → backend communication
REACT_APP_API_BASE_URL=http://localhost:8000
REACT_APP_BACKEND_URL=http://localhost:8000

# Frontend dev server port
PORT=3000

# ── Backend ─────────────────────────────────────────────────────
# Set these in backend/.env
# OPENWEATHER_API=your_openweather_api_key_here
# CORS_ORIGINS=http://localhost:3000,https://your-production-domain.com
# FLASK_ENV=development
# LOG_LEVEL=DEBUG